{
  "name": "red-raider-loyalty",
  "version": "1.0.0",
  "description": "Texas Tech Athletics — Student spot-reservation and loyalty points platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "seed": "node database/seed.js",
    "dev": "node --watch server.js",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "db:create": "wrangler d1 create red-raider-loyalty",
    "db:init": "wrangler d1 execute red-raider-loyalty --file=worker/schema.sql",
    "db:seed": "wrangler d1 execute red-raider-loyalty --file=worker/seed.sql"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.11.1",
    "connect-sqlite3": "^0.9.14",
    "express": "^4.18.2",
    "express-session": "^1.18.0"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
